# Production Environment Configuration
ENVIRONMENT=production

# PostgreSQL Database - Use actual production credentials
# Replace ${VAR} with actual values from your environment
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Connection Pool (Production - larger pool)
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO=false

# Security - MUST CHANGE THESE
# Generate secure keys:
# JWT_SECRET: openssl rand -hex 32
# ENCRYPTION_KEY: python -c "import secrets; print(secrets.token_hex(16))"
JWT_SECRET=${JWT_SECRET}
ENCRYPTION_KEY=${ENCRYPTION_KEY}

# LLM Configuration
DEFAULT_LLM_TIMEOUT=60
DEFAULT_LLM_MAX_TOKENS=4096
DEFAULT_LLM_TEMPERATURE=0.7

# Redis
REDIS_URL=${REDIS_URL}
