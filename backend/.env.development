# Development Environment Configuration
ENVIRONMENT=development

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://ai_learning:dev_password_change_in_prod@127.0.0.1:5432/learning_platform

# Connection Pool (Development - smaller pool)
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_ECHO=true

# Security (Development - unsafe keys)
JWT_SECRET=dev-jwt-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-32-chars-xx

# LLM Configuration
DEFAULT_LLM_TIMEOUT=30
DEFAULT_LLM_MAX_TOKENS=2048
DEFAULT_LLM_TEMPERATURE=0.7

# Redis
REDIS_URL=redis://localhost:6379/0
