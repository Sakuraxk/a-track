# ============================================================
#  智辙 (A-Track) — 环境变量配置模板
#  复制此文件为 .env 并修改其中的值
#  cp .env.example .env  (Linux/Mac)
#  Copy-Item .env.example .env  (PowerShell)
# ============================================================

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=ai_learning
POSTGRES_PASSWORD=dev_password_change_in_prod
POSTGRES_DB=learning_platform
# 宿主机端口（Windows 上可能需要避开冲突/保留端口，例如 15433）
POSTGRES_PORT=5432

# ── 后端数据库连接（本地开发用，端口需与 POSTGRES_PORT 保持一致）───
# 注意：Docker 部署时此项不需要修改，docker-compose.yml 中已自动配置
DATABASE_URL=postgresql+asyncpg://ai_learning:dev_password_change_in_prod@127.0.0.1:5432/learning_platform

# ── 环境 ──────────────────────────────────────
ENVIRONMENT=development
BACKEND_PORT=8010

# ── 前端端口（Docker 部署时对外暴露的端口）────
FRONTEND_PORT=80

# 可选：前端代理目标（frontend/vite.config.ts 使用，本地开发用）
# 留空时默认使用 http://localhost:${BACKEND_PORT}
# VITE_BACKEND_TARGET=http://localhost:8010

# ── 安全 ──────────────────────────────────────
# 【重要】生产环境部署前必须修改以下密钥！
# 生成 JWT_SECRET:      openssl rand -hex 32
# 生成 ENCRYPTION_KEY:  python -c "import secrets; print(secrets.token_hex(16))"
JWT_SECRET=dev-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-32-chars-xx

# ── 代码沙箱 ──────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_DOCKER_IMAGE=python-sandbox
SANDBOX_SERVICE_URL=http://sandbox-worker:8011/execute

# ── 系统 LLM（DeepSeek API）─────────────────
# 【重要】请在此处配置系统默认的 AI API Key（而不是 config.toml）
# 获取方式：访问 https://platform.deepseek.com/ 注册并创建 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ── Redis（可选）─────────────────────────────
# REDIS_URL=redis://localhost:6379/0
